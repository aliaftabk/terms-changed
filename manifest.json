{
  "manifest_version": 3,
  "name": "Terms Changed?",
  "description": "Watch important pages and see exactly what changed.",
  "version": "1.0.0",
  "action": {
    "default_title": "Terms Changed? — open side panel",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "side_panel": {
    "default_path": "src/sidepanel/sidepanel.html"
  },
  "background": {
    "service_worker": "src/background/service_worker.js",
    "type": "module"
  },
  "permissions": ["storage", "tabs", "activeTab", "scripting", "sidePanel"],
  "optional_permissions": ["alarms", "notifications"],
  "optional_host_permissions": ["https://*/*", "http://*/*"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
